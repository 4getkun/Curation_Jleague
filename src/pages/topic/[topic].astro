---
import Base from "../../layouts/Base.astro";
import NewsRow from "../../components/NewsRow.astro";
import TopicChipLink from "../../components/TopicChipLink.astro";
import { topics } from "../../lib/topics";
import { newsForTopic } from "../../lib/news";

export function getStaticPaths() {
  return topics.map((topic) => ({
    params: { topic: topic.id },
    props: { topic },
  }));
}

const { topic } = Astro.props;
const items = newsForTopic(topic.id);
---

<Base
  title={`#${topic.label}のニュース`}
  description={`J1全20クラブの「${topic.label}」に関する最新ニュースまとめ。広告なしで読めるJリーグキュレーションサイト。`}
>
  <section class="container-page" style="padding-top:32px; padding-bottom:20px; border-bottom:1px solid var(--rule-mid);">
    <div class="font-kicker" style="font-size:13px; font-weight:500; letter-spacing:3px; color:var(--accent);">
      話題タグ
    </div>
    <h1 class="font-display font-black m-0" style="font-size:clamp(26px, 4vw, 38px); margin-top:8px; color:var(--text);">
      #{topic.label}
    </h1>
    <div class="flex flex-wrap gap-2" style="margin-top:16px;">
      {topics.map((t) => (
        <TopicChipLink topic={t} active={t.id === topic.id} />
      ))}
    </div>
  </section>

  <section class="container-page" style="padding-top:20px; padding-bottom:64px;">
    {items.length > 0 ? (
      items.map((item, i) => <NewsRow item={item} variant="full" index={i + 1} />)
    ) : (
      <p style="font-size:14px; color:var(--text-muted); padding:24px 0;">
        現在、「{topic.label}」に関するニュースがまだ取得されていません。次回の自動更新をお待ちください。
      </p>
    )}
  </section>
</Base>
