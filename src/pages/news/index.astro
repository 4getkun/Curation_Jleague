---
import Base from "../../layouts/Base.astro";
import NewsRow from "../../components/NewsRow.astro";
import TopicChipLink from "../../components/TopicChipLink.astro";
import { allNews, newsGeneratedAt, formatGeneratedAt } from "../../lib/news";
import { teams } from "../../lib/teams";
import { topics } from "../../lib/topics";
import { withBase } from "../../lib/url";

const PAGE_SIZE = 20;
---

<Base title="ニュース一覧" description="J1全20クラブの最新ニュースを一覧でチェック。クラブごとの絞り込みにも対応。">
  <section class="container-page" style="padding-top:32px; padding-bottom:8px;">
    <div class="font-kicker" style="font-size:14px; font-weight:500; letter-spacing:4px; color:var(--accent);">ALL NEWS</div>
    <div class="flex items-baseline justify-between flex-wrap" style="gap:8px;">
      <h1 class="font-display font-bold m-0" style="font-size:clamp(26px, 4vw, 38px); margin-top:8px; color:var(--text);">ニュース一覧</h1>
      <div style="font-size:13px; color:var(--text-faint);">
        全{allNews.length}件
        {newsGeneratedAt && ` · 最終更新 ${formatGeneratedAt(newsGeneratedAt)}（自動更新）`}
      </div>
    </div>

    <div class="flex items-center flex-wrap" style="gap:10px; margin-top:24px; padding:16px 0; border-top:1px solid var(--rule-mid); border-bottom:1px solid var(--rule-weak);">
      <span style="font-size:12px; color:var(--text-faint); margin-right:2px;">絞り込み:</span>
      <span style="padding:6px 16px; background-color:var(--text); color:var(--page-bg); border-radius:999px; font-size:13px; font-weight:500;">すべて</span>
      <select
        onchange="if(this.value) location.href = this.value;"
        style="padding:6px 16px; border:1px solid var(--rule-mid); border-radius:999px; font-size:13px; background:none; color:var(--text);"
        aria-label="クラブで選ぶ"
      >
        <option value="">クラブで選ぶ ▾</option>
        {teams.map((team) => (
          <option value={withBase(`/team/${team.id}/`)}>{team.short}</option>
        ))}
      </select>
      {topics.map((topic) => (
        <TopicChipLink topic={topic} />
      ))}
    </div>
  </section>

  <section class="container-page" style="padding-top:8px; padding-bottom:24px;">
    <div id="news-grid" class="grid grid-cols-1 sm:grid-cols-2" style="column-gap:72px;">
      {allNews.map((item, i) => (
        <div class="news-page-item">
          <NewsRow item={item} variant="compact" index={i + 1} />
        </div>
      ))}
    </div>

    {allNews.length === 0 && (
      <p style="font-size:14px; color:var(--text-muted); padding:24px 0;">
        現在、ニュースがまだ取得されていません。次回の自動更新をお待ちください。
      </p>
    )}

    <div id="pagination" class="hidden flex justify-center items-center" style="gap:20px; margin-top:36px; font-size:14px;"></div>
  </section>
</Base>

<script define:vars={{ pageSize: PAGE_SIZE }}>
  (function () {
    var items = Array.from(document.querySelectorAll("#news-grid .news-page-item"));
    var pager = document.getElementById("pagination");
    var pageCount = Math.ceil(items.length / pageSize);
    var currentPage = 1;

    if (pageCount <= 1) return;

    function render() {
      items.forEach(function (el, i) {
        var page = Math.floor(i / pageSize) + 1;
        el.style.display = page === currentPage ? "" : "none";
      });

      var parts = [];
      parts.push(
        currentPage > 1
          ? '<a href="#" data-page="' + (currentPage - 1) + '" style="color:var(--text); font-weight:700;">← 前へ</a>'
          : '<span style="color:var(--num);">← 前へ</span>',
      );
      for (var p = 1; p <= pageCount; p++) {
        if (p === currentPage) {
          parts.push(
            '<span style="width:32px; height:32px; display:grid; place-items:center; background-color:var(--text); color:var(--page-bg);">' +
              p +
              "</span>",
          );
        } else {
          parts.push(
            '<a href="#" data-page="' +
              p +
              '" style="width:32px; height:32px; display:grid; place-items:center; border:1px solid var(--rule-mid); color:var(--text); text-decoration:none;">' +
              p +
              "</a>",
          );
        }
      }
      parts.push(
        currentPage < pageCount
          ? '<a href="#" data-page="' + (currentPage + 1) + '" style="color:var(--text); font-weight:700;">次へ →</a>'
          : '<span style="color:var(--num);">次へ →</span>',
      );
      pager.innerHTML = parts.join("");
      pager.classList.remove("hidden");

      pager.querySelectorAll("a[data-page]").forEach(function (a) {
        a.addEventListener("click", function (e) {
          e.preventDefault();
          currentPage = parseInt(a.getAttribute("data-page"), 10);
          render();
          pager.scrollIntoView({ behavior: "smooth", block: "nearest" });
        });
      });
    }

    render();
  })();
</script>
