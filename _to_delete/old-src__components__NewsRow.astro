---
import type { NewsItem } from "../lib/news";
import { formatRelativeShort } from "../lib/news";
import { getTeam } from "../lib/teams";
import { getTopic } from "../lib/topics";
import { withBase } from "../lib/url";

interface Props {
  item: NewsItem;
  /** "full": 通常サイズ(番号34px) / "compact": やや小さめ(アーカイブ一覧の2カラム等、番号30px) */
  variant?: "full" | "compact";
  /** false の場合、メタ行からクラブ名を省く(クラブページなど、既に球団が自明なとき) */
  showTeamLabel?: boolean;
  /**
   * 指定すると、記事側の判定結果(teams[0])に関わらずこのクラブの色で
   * 表示する。クラブページで「今見ているクラブと違う色のドットが出て、別クラブの
   * 記事に見える」のを防ぐために使う。
   */
  forceTeamId?: string;
  /** 記事の連番(1始まり)。指定するとOswaldの大きな番号を左側に表示する */
  index?: number;
}

const { item, variant = "full", showTeamLabel = true, forceTeamId, index } = Astro.props;

const primary = getTeam(forceTeamId ?? item.teams[0] ?? "");
const teamColor = primary?.color ?? "var(--num)";
const teamShort = primary?.short ?? "総合";

const metaParts = [item.source, formatRelativeShort(item.pubDate)].filter(Boolean);

const isCompact = variant === "compact";
// 同じ出来事を複数メディアが報じている場合、代表記事以外の出典
const extraSources = (item.sources ?? []).slice(1);
const itemTopics = (item.topics ?? []).map((id) => getTopic(id)).filter((t): t is NonNullable<typeof t> => Boolean(t));

const numColumn = isCompact ? "44px" : "64px";
const numSize = isCompact ? "26px" : "34px";
const titleSize = isCompact ? "17px" : "19px";
---

<article
  class="grid"
  style={`grid-template-columns:${index !== undefined ? numColumn : "0"} 1fr; gap:${index !== undefined ? "20px" : "0"}; padding:20px 0; border-bottom:1px solid var(--rule-weak);`}
>
  {index !== undefined && (
    <div class="font-kicker" style={`font-size:${numSize}; font-weight:500; color:var(--num); line-height:1;`}>
      {String(index).padStart(2, "0")}
    </div>
  )}
  <div class="min-w-0">
    <a href={item.link} target="_blank" rel="noopener noreferrer nofollow" class="block no-underline" style="color:inherit;">
      <h3 class="font-display font-semibold leading-snug m-0" style={`font-size:${titleSize}; line-height:1.7; color:var(--text);`}>
        {item.title}
      </h3>
      {!isCompact && item.summary && (
        <p class="m-0 mt-1.5" style="font-size:13px; line-height:1.7; color:var(--text-muted);">{item.summary}</p>
      )}
    </a>
    <div class="flex flex-wrap items-center" style="gap:8px; font-size:12px; color:var(--text-faint); margin-top:10px;">
      {showTeamLabel && (
        <span style={`display:inline-block; padding-bottom:2px; border-bottom:2px solid ${teamColor}; font-weight:700; color:var(--text);`}>
          {teamShort}
        </span>
      )}
      <span>{metaParts.join(" · ")}</span>
      {extraSources.length > 0 && (
        <span>
          ・ほか{extraSources.length}社:
          {extraSources.map((s) => (
            <>
              {" "}
              <a
                href={s.link}
                target="_blank"
                rel="noopener noreferrer nofollow"
                class="link-underline"
                style="color:var(--text-faint);"
              >{s.name}</a>
            </>
          ))}
        </span>
      )}
    </div>
    {itemTopics.length > 0 && (
      <div class="flex flex-wrap" style="gap:6px; margin-top:10px;">
        {itemTopics.map((topic) => (
          <a
            href={withBase(`/topic/${topic.id}/`)}
            class="no-underline"
            style="font-size:11px; padding:2px 10px; border:1px solid var(--rule-mid); border-radius:999px; color:var(--text);"
          >
            #{topic.label}
          </a>
        ))}
      </div>
    )}
  </div>
</article>
