---
import { teams } from "../lib/teams";
import { withBase } from "../lib/url";

interface Props {
  /** トップページだけ44px+サブコピー付きの大きいマストヘッドにする */
  large?: boolean;
}

const { large = false } = Astro.props;

const path = new URL(Astro.request.url).pathname;
const base = import.meta.env.BASE_URL;
const rel = path.startsWith(base) ? path.slice(base.length - 1) : path;

const navLinks = [
  { href: withBase("/"), label: "トップ", match: (p: string) => p === "/" || p === "" },
  { href: withBase("/news/"), label: "ニュース一覧", match: (p: string) => p.startsWith("/news") },
  { href: withBase("/team/"), label: "クラブ別", match: (p: string) => p.startsWith("/team") },
  { href: withBase("/topic/"), label: "話題から探す", match: (p: string) => p.startsWith("/topic") },
  { href: withBase("/search/"), label: "検索", match: (p: string) => p.startsWith("/search") },
];
---

<header style="background-color:var(--page-bg); border-bottom:3px solid var(--rule-strong);">
  <div
    class:list={["container-page flex items-end justify-between gap-4 flex-wrap", large ? "py-6 sm:py-8" : "py-4 sm:py-5"]}
  >
    <a href={withBase("/")} class="no-underline shrink-0">
      <div
        class="font-display font-black"
        style={`color:var(--text); letter-spacing:0.02em; line-height:1; font-size:${large ? "clamp(21px, 5.5vw, 44px)" : "clamp(19px, 4vw, 30px)"};`}
      >
        Curation Jleague
      </div>
      {large && (
        <div class="hidden sm:block" style="font-size:12px; color:var(--text-faint); margin-top:6px;">
          広告ゼロで読める、J1全20クラブのニュースキュレーション
        </div>
      )}
    </a>

    <div class="flex items-center gap-4 sm:gap-6">
      <nav class="hidden md:flex items-center gap-6 text-[14px] font-medium">
        {navLinks.map((link) => (
          <a
            href={link.href}
            class="pb-1 no-underline"
            style={`color:var(--text); border-bottom:2px solid ${link.match(rel) ? "var(--accent)" : "transparent"};`}
          >
            {link.label}
          </a>
        ))}
        <select
          class="my-team-select font-bold"
          aria-label="マイクラブを選択"
          style="font-size:13px; padding:5px 8px; border:1px solid var(--text); border-radius:0; color:var(--accent); background-color:transparent; max-width:120px;"
        >
          <option value="">★ マイクラブ</option>
          {teams.map((team) => <option value={team.id}>{team.short}</option>)}
        </select>
      </nav>

      <div class="flex items-center rounded-full overflow-hidden text-[12px]" style="border:1px solid var(--text);">
        <button
          type="button"
          id="theme-toggle-light"
          aria-label="ライトテーマにする"
          class="theme-pill-btn"
          style="padding:4px 11px; border:none; cursor:pointer; background:none; color:var(--text); font-size:13px; line-height:1;"
        >☀</button>
        <button
          type="button"
          id="theme-toggle-dark"
          aria-label="ダークテーマにする"
          class="theme-pill-btn"
          style="padding:4px 11px; border:none; cursor:pointer; background:none; color:var(--text); font-size:13px; line-height:1;"
        >☾</button>
      </div>

      <button
        id="menu-toggle"
        type="button"
        aria-label="メニューを開く"
        class="md:hidden grid h-[30px] w-[30px] place-items-center"
        style="background:none; border:none; color:var(--text); cursor:pointer;"
      >
        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 6h16M4 12h16M4 18h16"/></svg>
      </button>
    </div>
  </div>

  <!-- クラブチップ帯(モバイルのみ)。デスクトップではCLUBSセクション(各ページ
       本文側)にクラブ一覧を出すため、ヘッダー内には表示しない。 -->
  <div class="md:hidden team-quicknav" style="overflow-x:auto; border-top:1px solid var(--rule-weak);">
    <div class="flex" style="gap:8px; padding:12px 24px; width:max-content;">
      {teams.map((team) => (
        <a
          href={withBase(`/team/${team.id}/`)}
          class="no-underline flex items-center shrink-0"
          style="gap:6px; padding:5px 12px; border:1px solid var(--rule-mid); border-radius:999px; font-size:12px; color:var(--text); white-space:nowrap;"
        >
          <span class="inline-block rounded-full" style={`width:7px; height:7px; background-color:${team.color};`}></span>
          {team.short}
        </a>
      ))}
    </div>
  </div>

  <!-- モバイルメニュー -->
  <div id="mobile-menu" class="hidden md:hidden" style="border-top:1px solid var(--rule-weak);">
    <nav class="container-page flex flex-col py-3 text-sm font-bold">
      {navLinks.map((link) => (
        <a
          href={link.href}
          class="py-2.5 no-underline"
          style={`border-bottom:1px solid var(--rule-weak); color:var(--text);`}
        >
          {link.label}
        </a>
      ))}
      <a href={withBase("/about/")} class="py-2.5 no-underline" style="border-bottom:1px solid var(--rule-weak); color:var(--text);">
        このサイトについて
      </a>
      <label class="py-3 flex items-center gap-2.5" style="color:var(--text-faint);">
        <span style="font-weight:700; color:var(--accent);">★ マイクラブ</span>
        <select
          class="my-team-select flex-1"
          aria-label="マイクラブを選択(モバイル)"
          style="font-size:13px; padding:6px 10px; border:1px solid var(--text); border-radius:0; color:var(--text); background-color:transparent;"
        >
          <option value="">未設定</option>
          {teams.map((team) => <option value={team.id}>{team.short}</option>)}
        </select>
      </label>
    </nav>
  </div>
</header>

<style>
  /* テーマ切替ピル: アクティブ側だけ塗りつぶす(ライト=☀左側、ダーク=☾右側)。
     .dark クラスの有無で自動的に見た目が入れ替わる。 */
  #theme-toggle-light {
    background-color: var(--text);
    color: var(--page-bg);
  }
  :global(.dark) #theme-toggle-light {
    background-color: transparent;
    color: var(--text);
  }
  :global(.dark) #theme-toggle-dark {
    background-color: var(--text);
    color: var(--page-bg);
  }
</style>

<script is:inline>
  function setTheme(dark) {
    const root = document.documentElement;
    root.classList.toggle("dark", dark);
    localStorage.setItem("jleague-curation-theme", dark ? "dark" : "light");
  }
  document.getElementById("theme-toggle-light")?.addEventListener("click", () => setTheme(false));
  document.getElementById("theme-toggle-dark")?.addEventListener("click", () => setTheme(true));
  document.getElementById("menu-toggle")?.addEventListener("click", () => {
    document.getElementById("mobile-menu")?.classList.toggle("hidden");
  });

  // マイクラブ(お気に入りクラブ)の選択をlocalStorageに保存する。
  // トップページ側はこの値を読んで「マイクラブの最新ニュース」を表示する。
  (function () {
    var STORAGE_KEY = "jleague-curation-my-team";
    var selects = document.querySelectorAll(".my-team-select");
    var saved = "";
    try {
      saved = localStorage.getItem(STORAGE_KEY) || "";
    } catch (e) {}
    selects.forEach(function (sel) {
      sel.value = saved;
      sel.addEventListener("change", function () {
        try {
          if (sel.value) {
            localStorage.setItem(STORAGE_KEY, sel.value);
          } else {
            localStorage.removeItem(STORAGE_KEY);
          }
        } catch (e) {}
        // 他のセレクト(デスクトップ/モバイル)にも同じ値を反映してからリロード
        selects.forEach(function (other) {
          other.value = sel.value;
        });
        location.reload();
      });
    });
  })();
</script>
