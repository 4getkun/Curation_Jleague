---
import type { Team } from "../lib/teams";
import { textOnTeamColor } from "../lib/teams";
import { withBase } from "../lib/url";

interface Props {
  team: Team;
  active?: boolean;
}

const { team, active = false } = Astro.props;
const style = active
  ? `background-color:${team.color}; color:${textOnTeamColor(team.color)}; border-color:${team.color};`
  : `background:none; color:var(--text); border-color:var(--rule-mid);`;
---

<a
  href={withBase(`/team/${team.id}/`)}
  class="no-underline rounded-full border font-medium"
  style={`font-size:13px; padding:6px 14px; ${style}`}
>
  {team.short}
</a>
