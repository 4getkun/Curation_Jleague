---
import type { Topic } from "../lib/topics";
import { withBase } from "../lib/url";

interface Props {
  topic: Topic;
  active?: boolean;
}

const { topic, active = false } = Astro.props;
const style = active
  ? `background-color:var(--text); color:var(--page-bg); border-color:var(--text);`
  : `background:none; color:var(--text); border-color:var(--rule-mid);`;
---

<a
  href={withBase(`/topic/${topic.id}/`)}
  class="no-underline rounded-full border"
  style={`font-size:13px; padding:6px 14px; ${style}`}
>
  #{topic.label}
</a>
