---
import type { Team } from "../lib/teams";
import { withBase } from "../lib/url";

interface Props {
  team: Team;
}

const { team } = Astro.props;
---

<a
  href={withBase(`/team/${team.id}/`)}
  class="flex items-center no-underline"
  style={`gap:9px; background-color:var(--card-bg); border:1px solid var(--border); border-top:3px solid ${team.color}; padding:12px 14px; color:var(--text);`}
>
  <span class="flex-1 font-medium" style="font-size:14px;">{team.name}</span>
  <span style="color:var(--text-faint);">→</span>
</a>
