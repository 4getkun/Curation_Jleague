---
import Base from "../../layouts/Base.astro";
import TeamLinkRow from "../../components/TeamLinkRow.astro";
import { teams } from "../../lib/teams";
---

<Base title="クラブ別ニュース" description="J1全20クラブを選んでニュースを確認できます。">
  <section class="container-page" style="padding:44px 24px 64px;">
    <h1 class="font-display font-black m-0" style="font-size:28px; color:var(--text); margin-bottom:6px;">クラブ別ニュース</h1>
    <p style="font-size:14px; color:var(--text-muted); margin-bottom:32px;">
      J1全20クラブから選んで最新ニュースを確認できます。
    </p>

    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
      {teams.map((team) => (
        <TeamLinkRow team={team} />
      ))}
    </div>
  </section>
</Base>
